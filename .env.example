# Set these in Vercel: Project Settings -> Environment Variables.
# Do NOT commit real values. This file is just a template.
# First Paycheck gets its OWN Vercel project, repo, and Supabase key.

# The single password you type to enter the app.
APP_PASSWORD=choose-a-strong-password

# Your Anthropic (Claude) API key, from console.anthropic.com -> API keys.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Set to the fast model at runtime for the demo / Fliki video. Build with the strong model.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# From your Supabase project: Settings -> API.
# URL is the "Project URL". The key is the SERVICE ROLE key (server-side only).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
